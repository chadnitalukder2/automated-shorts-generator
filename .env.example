# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Anthropic Claude ───────────────────────────────────────────────────────────
# ── AI Provider (pick one free option below) ───────────────────────────────────
AI_PROVIDER=gemini

# Option 1: Google Gemini (FREE — 1500 req/day)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Option 2: Groq (FREE — fast Llama 3)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Option 3: Anthropic Claude (PAID)
ANTHROPIC_API_KEY=sk-ant-...

# ── News API ───────────────────────────────────────────────────────────────────
# Get key from https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here
# Optional: specific cricket API
CRICKET_API_KEY=

# ── Edge TTS ───────────────────────────────────────────────────────────────────
# Voice options: en-US-GuyNeural, en-US-AriaNeural, en-IN-NeerjaNeural, en-GB-RyanNeural
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+10%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz

# ── YouTube API ────────────────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxx

# ── Video Settings ─────────────────────────────────────────────────────────────
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_DURATION_SECONDS=55

# ── Shorts Config ──────────────────────────────────────────────────────────────
CHANNEL_NAME=CricketViralShorts
MAX_DAILY_UPLOADS=3
UPLOAD_ENABLED=true
CRON_SCHEDULE="0 8,14,20 * * *"

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./outputs
CLEANUP_AFTER_UPLOAD=true
